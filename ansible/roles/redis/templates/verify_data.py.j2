#!/usr/bin/env python3
import hashlib
import subprocess
import json

def verify_data_advanced():
    keys_read = 0
    missing_keys = 0
    mismatched_values = 0
    
    # ஜாவா கண்டுபிடித்து அன்சிபிள் வழியாக தரும் எண்ணிக்கையை வாங்குகிறோம்
    total_keys_input = int("{{ target_keys }}")
    
    for i in range(1, total_keys_input + 1):
        key = f"key:{i:04d}"
        
        # 1. Recompute the exact expected SHA256 hash locally
        expected_value = hashlib.sha256(key.encode('utf-8')).hexdigest()
        
        # 2. Execute redis-cli with -c flag to fetch the key across the cluster
        cmd = ["redis-cli", "-h", "127.0.0.1", "-c", "-p", "6379", "GET", key]
        
        try:
            result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            
            # Split the output by newlines and take the last line to bypass the '-> Redirected...' message
            output_lines = result.stdout.strip().split('\n')
            actual_value = output_lines[-1].strip() if output_lines else ""
            
            if not actual_value or actual_value == "(nil)":
                missing_keys += 1
            elif actual_value == expected_value:
                keys_read += 1
            else:
                mismatched_values += 1
                
        except Exception:
            missing_keys += 1
            
    # 4. Strict formatting of the required PDF pass/fail strings dynamically
    if missing_keys == 0 and mismatched_values == 0:
        pdf_message = f"PASS — {keys_read}/{total_keys_input} keys verified"
    else:
        pdf_message = f"FAIL — {missing_keys} keys missing, {mismatched_values} values mismatched"
        
    summary = {
        "status": "PASS" if (missing_keys == 0 and mismatched_values == 0) else "FAIL",
        "keys_successfully_verified": keys_read,
        "missing_keys": missing_keys,
        "mismatched_values": mismatched_values,
        "pdf_formatted_output": pdf_message
    }
    
    # Print exactly to stdout for the Java wrapper to parse and display
    print(json.dumps(summary))

if __name__ == "__main__":
    verify_data_advanced()